# ============ IDENTIDADE / MARCA ============
DASH_NAME="Minha Operação"        # nome exibido no dashboard
DASH_COLOR="#6d28d9"              # cor primária (hex #rrggbb)
DASH_LOGO_URL="/logo.svg"         # opcional; caminho/URL do logo
DASH_DOMAIN="dash.seudominio.com" # domínio onde o dashboard responde (DNS A → esta VPS)
LETSENCRYPT_EMAIL=""              # opcional; e-mail p/ avisos do certificado

# ============ ACESSO ============
DASH_KEY=""                       # senha de acesso ao dashboard (escolha uma forte)

# ============ KOMMO (CRM) ============
KOMMO_SUBDOMAIN=""                # ex.: minhaconta (de minhaconta.kommo.com)
KOMMO_TOKEN=""                    # token de longa duração (integração Kommo)
KOMMO_PIPELINES=""                # IDs dos pipelines comerciais, separados por vírgula
STATUS_AGENDADO=""                # use 'discover' p/ achar os IDs abaixo
STATUS_NOSHOW=""
STATUS_CANCELADO=""
STATUS_FOLLOWUP=""
STATUS_WON="142"                  # 142 é o padrão do Kommo p/ "Venda ganha"
STATUS_LOST="143"                 # 143 é o padrão p/ "Venda perdida"
FIELD_UTM_SOURCE=""               # IDs dos campos custom de lead
FIELD_UTM_CAMPAIGN=""
FIELD_UTM_CONTENT=""
FIELD_PRODUTO=""

# ============ META ADS ============
META_TOKEN=""                     # token System User com escopo ads_read
META_AD_ACCOUNT=""                # ex.: act_1234567890
META_RESULT_ACTIONS="lead,offsite_conversion.fb_pixel_lead"  # action_types que contam como resultado

# ============ EVOLUTION (WhatsApp) — opcional ============
EVOLUTION_INSTANCE=""             # nome da instância; vazio desativa
EVOLUTION_URL=""                  # ex.: https://api.seuwpp.com
EVOLUTION_KEY=""                  # apikey da Evolution

# ============ ALERTAS — opcional ============
ALERT_WEBHOOK_URL=""              # webhook (ex.: Discord/Slack) p/ alertas de sync

# ============ TRAEFIK (Modo A — VPS compartilhada / Swarm) — opcional ============
# Só usado pelo deploy-traefik.sh. Preencha com os nomes do SEU Traefik.
TRAEFIK_NETWORK="traefik-public"            # nome da rede overlay externa do seu Traefik
TRAEFIK_ENTRYPOINT="websecure"              # entrypoint HTTPS do seu Traefik
TRAEFIK_CERTRESOLVER="letsencryptresolver"  # certresolver (Let's Encrypt) do seu Traefik

# ============ BACKUP (Litestream) — opcional ============
LITESTREAM_BUCKET=""              # bucket S3-compatível; vazio desativa o backup
LITESTREAM_ENDPOINT=""            # ex.: https://<accountid>.r2.cloudflarestorage.com
LITESTREAM_ACCESS_KEY_ID=""
LITESTREAM_SECRET_ACCESS_KEY=""
